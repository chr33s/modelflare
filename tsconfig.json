{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node", "mocha"]
  },
  "include": ["src/**/*", "vscode.proposed.*.d.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}
